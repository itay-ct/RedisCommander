{
  "slug": "zrangestore",
  "title": "ZRANGESTORE",
  "description": "Stores a range of members from sorted set in a key.",
  "docsUrl": "https://redis.io/docs/latest/commands/zrangestore/",
  "group": "sorted-set",
  "groupLabel": "Sorted Sets",
  "syntax": "ZRANGESTORE dst src min max [BYSCORE | BYLEX] [REV] [LIMIT offset\n  count]",
  "complexity": "O(log(N)+M) with N being the number of elements in the sorted set and M the number of elements stored into the destination key.",
  "since": "6.2.0",
  "arity": -5,
  "aclCategories": [
    "@write",
    "@sortedset",
    "@slow"
  ],
